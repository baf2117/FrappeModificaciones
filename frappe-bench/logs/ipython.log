2026-04-17 10:45:36,613 INFO ipython import frappe
2026-04-17 10:45:36,613 INFO ipython paths = ['/private/files/Recurso 2.png','/private/files/favicon.ico']
2026-04-17 10:45:36,613 INFO ipython for p in paths:
    name = frappe.db.get_value('File', {'file_url': p}, 'name')
    print('\nfile_url=', p, 'name=', name)
    if not name:
        continue
    f = frappe.get_doc('File', name)
    print('before is_private=', f.is_private, 'new_file_url=', f.file_url)
    f.is_private = 0
    f.save(ignore_permissions=True)
    f.reload()
    print('after  is_private=', f.is_private, 'new_file_url=', f.file_url)
frappe.db.commit()
2026-04-17 10:45:36,614 INFO ipython print('\nWebsite Settings banner_image=', frappe.db.get_single_value('Website Settings','banner_image'))
2026-04-17 10:45:36,614 INFO ipython print('Website Settings favicon=', frappe.db.get_single_value('Website Settings','favicon'))
